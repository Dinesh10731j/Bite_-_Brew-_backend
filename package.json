{
  "name": "bite-brew-cafe-backend",
  "version": "1.0.0",
  "description": "Bite Brew Cafe Backend with Express, TypeScript, PostgreSQL, TypeORM, auth, queues, etc.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:nodemon": "nodemon --watch src --ext ts --exec \"ts-node src/index.ts\"",
    "start:nodemon": "nodemon dist/index.js",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,js,json,yml,yaml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,yml,yaml,md}\"",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand --selectProjects unit",
    "test:integration": "jest --runInBand --selectProjects integration --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "ci:verify": "npm run lint && npm run test:coverage && npm run build"
  },
  "keywords": [
    "express",
    "typescript",
    "postgres",
    "typeorm"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.911.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.8.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "geoip-lite": "^2.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^5.0.3",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^1.0.39",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "node-cron": "^3.0.3",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
